<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Knovault 只使用公開套件。此處 <clear /> 會清掉繼承自機器/使用者層級的
    套件來源（含目前無法連線的私有 LAN feed 192.168.10.31:5555），
    只保留 nuget.org，避免還原時卡在無法連線的來源上。
    若日後需要私有 feed，在這裡 <add> 回來即可。
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
